# ── RK3566 / OrangePi CM4 Monitor – environment variables ────────────────────
# Copy this file to .env and adjust as needed.
# docker-compose automatically reads .env from the same directory.

# Web dashboard port on the host machine
HOST_PORT=8080

# How often metrics are collected (seconds)
POLL_INTERVAL=10

# How many days of data to retain in the database
RETENTION_DAYS=14

# Logging verbosity: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
